# Copy to .env for `docker compose up`. Defaults below work out of the box.

# --- Postgres ---
POSTGRES_USER=workout
POSTGRES_PASSWORD=workout_dev_password
POSTGRES_DB=workout

# --- Server ---
DATABASE_URL=postgresql://workout:workout_dev_password@postgres:5432/workout?schema=public
SERVER_PORT=4000
CLIENT_ORIGIN=http://localhost:8080
NODE_ENV=production

# --- Client (baked at build time) ---
VITE_API_URL=http://localhost:4000
